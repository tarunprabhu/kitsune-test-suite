#!/usr/bin/env sh
#
# This runs the tests, then generates a report containing the following:
#
#   - The date and time when the tests were run
#   - Information about the CPU and the GPU(s) on which the tests were run
#   - Compile-and-execution time statistics
#
# This is most useful when the test suite is configured in benchmarking mode,
# but it may also be used when just running the correctness tests.

lit="@TEST_SUITE_LIT@"
lit_flags="@TEST_SUITE_LIT_FLAGS@"

trim() {
    expr='s/^[[:space:]]*//;s/[[:space:]]*$//'
    if [ $# -eq 0 ]; then
        cat /dev/stdin | sed ${expr}
    else
        echo $1 | sed ${expr}
    fi
}

exe=$(basename $0)

usage="${exe} [OPTIONS]
${exe} -h for more information"

help="
Run the Kitsune tests, then combines details about the platform on which the
tests are run (number and type of GPU's, CPU core count etc.), together with
compile-time, and execution time statistics into a single, more concise, report

USAGE

    ${exe} [OPTIONS]

OPTIONS

    -h          Show help and exit

    -o <file>   Where to write the combined report. If this is not given, the
                report will be written to report.json in Kitsune/ within the
                kitsune-test-suite build directory
"

# This will be the Kitsune/ subdirectory within the root of the llvm-test-suite
# build directory
kitsune=$(dirname $0)

# The root of the llvm-test-suite build directory.
test_suite=$(dirname "${kitsune}")

# The default location of the combined report.
outfile="${kitsune}/report.json"

while getopts "ho:" opt; do
    case "${opt}" in
    h)
        echo "${help}"
        exit 0
        ;;
    o)
        outfile="${OPTARG}"
        ;;
    *)
        echo ""
        echo "${usage}"
        exit 1
        ;;
    esac
done
shift $((OPTIND - 1))

if [ $# -gt 0 ]; then
    echo "Unexpected argument: '$1'"
    echo ""
    echo "${usage}"
    exit 1
fi

if [ -z "${lit}" ]; then
    echo "ERROR: 'lit' executable not found"
    echo
    echo "Reconfigure kitsune-test-suite with -DTEST_SUITE_LIT=<path/to/lit>"
    exit 1
elif [ ! -x "${lit}" ]; then
    echo "ERROR: ${lit} is not executable"
    exit 1
fi

# lit_flags will have been set in CMake. It may use a semicolon as a separator.
# We don't expect any other uses of semicolons, so just replace them with
# spaces.
lit_flags=$(echo "${lit_flags}" | tr ';' ' ')

# TODO: It is not clear that we need NO_STOP_MESSAGE=1 for the Fortran tests,
# but keep it for now. We will definitely want to revisit this at some point.
export NO_STOP_MESSAGE=1
${lit} ${lit_flags} -o ${kitsune}/ts-report.json ${kitsune}

# This should return a non-zero exit code if any tests failed.
pass=$?

lscpu=$(command -v lscpu)
uname=$(command -v uname)
tr=$(command -v tr)
if [ -n "${uname}" ] && [ -n "${tr}" ]; then
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
fi

cpu="<<UNKNOWN>>"
cores="0"
if [ -n "${lscpu}" ]; then
    cpuinfo=$(lscpu)
    cpu=$(echo "${cpuinfo}" |
        grep "Model name" |
        sed 's/Model name\s*:\s*//g' |
        sort |
        uniq)
    tpc=$(echo "${cpuinfo}" |
        grep "Thread(s) per core\s*:" |
        grep -oE "[0-9]+")
    cps=$(echo "${cpuinfo}" |
        grep "Core(s) per socket\s*:" |
        grep -oE "[0-9]+")
    sockets=$(echo "${cpuinfo}" |
        grep "Socket(s)\s*:" |
        grep -oE "[0-9]+")
    cores=$((tpc * cps * sockets))
elif [ "${os}" = "linux" ]; then
    cpu=$(cat /proc/cpuinfo |
        grep "model name" |
        sed 's/model name\s*:\s*//g' |
        sort |
        uniq)
    cores=$(cat /proc/cpuinfo |
        grep "processor" |
        sed 's/processor\s*:\s*//g' |
        wc -l)
elif [ "${os}" = "darwin" ]; then
    cpu=$(sysctl -n machdep.cpu.brand_string | trim)
    cores=$(sysctl -n hw.ncpu | trim)
elif [ "${os}" = "freebsd" ]; then
    cpu=$(sysctl -n hw.model | trim)
    cores=$(sysctl -n hw.ncpu | trim)
else
    echo "Could not determine CPU info"
fi

nvidia_smi=$(command -v nvidia-smi)
[ $? -ne 0 ] && nvidia_smi=""

rocm_smi=$(command -v rocm-smi)
[ $? -ne 0 ] && rocm_smi=""

# There could be more than one GPU on the machine. It would be good to determine
# which one was actually used, but at the time of writing, we cannot. It is
# unlikely that the suite will be run on a node with a variety of different
# GPU's on it. The more likely case is that there are multiple devices of the
# same model. Optimize for that scenario but be flexible enough to record all
# the GPU's if that is not the case.
gpus=""
count=0
if [ -n "${nvidia_smi}" ]; then
    # If no GPU's are found, nvidia-smi -L will return an error code.
    report=$(nvidia-smi -L)
    if [ $? -eq 0 ]; then
        names=$(echo "${report}" |
            sed -E 's/GPU[ ]*[0-9]+:[ ]*//g' |
            sed -E 's/[ ]*[(]UUID:[ ]*.+[)]//g' |
            sort |
            uniq)
        n=$(echo "${names}" | wc -l)
        namelist=$(echo "${names}" |
            tr '\n' ';' |
            sed -E 's/;$//g')
        [ -n "${gpus}" ] && gpus="${gpus};"
        gpus="${gpus}${namelist}"
        count=$((count + n))
    fi
fi
if [ -n "${rocm_smi}" ]; then
    # rocm-smi will never return an error code, even if no GPU's were found.
    # Instead, stdout will be empty with errors in stderr.
    report=$(rocm-smi -i 2>/dev/null)
    if [ -n "${report}" ]; then
        names=$(rocm-smi -i |
            grep "Device Name" |
            awk -F':' '{print $3;}' |
            sed -E 's/^\s*//g' |
            sort |
            uniq)
        n=$(echo "${names}" | wc -l)
        namelist=$(echo "${names}" |
            tr '\n' ';' |
            sed -E 's/;$//g')
        [ -n "${gpus}" ] && gpus="${gpus};"
        gpus="${gpus}${namelist}"
        count=$((count + n))
    fi
fi

date=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
host=$(hostname)

# Determine the version of Kitsune used when building these tests. We cannot
# assume that it will be in $PATH, so look at the CMakeCache.txt in the root of
# the test suite build directory. This should always be available. Kitsune's C
# frontend should always be available.
version=""
kitcc=$(grep "C_COMPILER:" "${test_suite}/CMakeCache.txt" |
    grep -oE "=.+$" |
    tr -d '=')
if [ -n "${kitcc}" ]; then
    version=$(${kitcc} --version |
        head -n 1 |
        grep -oE "version.+$" |
        sed 's/version[ ]*//g')
fi

platform="{
  \"date\": \"${date}\",
  \"version\": \"${version}\",
  \"hostname\": \"${host}\",
  \"cpu\": {
    \"model\": \"${cpu}\",
    \"cores\": ${cores}
  },
  \"gpu\": {
    \"count\": ${count},
    \"devices\": \"${gpus}\"
  }
}"

echo "${platform}" >${kitsune}/platform.json

# Generate the combined report. There is no reason to do this as a separate
# step. It can always be done separately if needed. The -b option must be
# given the root of the test suite.
${kitsune}/utils/kit-combine \
    -b "${test_suite}" \
    -o "${outfile}" \
    "${kitsune}/ts-report.json"

exit ${pass}
